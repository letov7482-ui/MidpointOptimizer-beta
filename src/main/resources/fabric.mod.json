{
  "schemaVersion": 1,
  "id": "midpoint-optimizer",
  "version": "${version}",
  "name": "MidpointOptimizer",
  "description": "Advanced FPS optimizer with Smart Optimizer and Low End Mode",
  "authors": ["Midpoint"],
  "contact": {
    "homepage": "https://github.com/Midpoint/MidpointOptimizer",
    "sources": "https://github.com/Midpoint/MidpointOptimizer"
  },
  "license": "MIT",
  "icon": "assets/midpoint-optimizer/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.midpointoptimizer.MidpointOptimizer"
    ],
    "modmenu": [
      "com.midpointoptimizer.gui.ModMenuIntegration"
    ]
  },
  "mixins": [
    "midpoint-optimizer.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": ">=${fabric_version}",
    "java": ">=21"
  },
  "recommends": {
    "modmenu": ">=${modmenu_version}"
  },
  "breaks": {
    "optifabric": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/midpoint"
      },
      "update_checker": true
    }
  }
}
